{
  "name": "signalk-ssl",
  "version": "0.1.5",
  "description": "SSL/TLS certificate management plugin for SignalK Node Server — generate a local CA, issue server certs, distribute the root via QR to phones/tablets",
  "type": "module",
  "main": "dist/plugin/index.js",
  "types": "dist/plugin/index.d.ts",
  "files": [
    "dist",
    "public",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build:plugin": "tsc -p tsconfig.json",
    "build:webapp": "vite build",
    "build:all": "npm run build:plugin && npm run build:webapp",
    "build": "npm run build:all",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.webapp.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}' 'tests/**/*.{ts,tsx}' '*.{js,mjs,ts,json,md}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css}' 'tests/**/*.{ts,tsx}' '*.{js,mjs,ts,json,md}'",
    "prepublishOnly": "npm run build:all"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-utility"
  ],
  "author": "Dirk",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dirkwa/signalk-ssl.git"
  },
  "bugs": {
    "url": "https://github.com/dirkwa/signalk-ssl/issues"
  },
  "homepage": "https://github.com/dirkwa/signalk-ssl#readme",
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "displayName": "SignalK SSL",
    "appstore": {
      "displayName": "SignalK SSL",
      "categories": [
        "utilities"
      ],
      "author": "Dirk",
      "description": "Generate a local CA and issue trusted HTTPS certificates for your SignalK server; install the root on phones/tablets via QR code."
    },
    "webapp": {
      "name": "SignalK SSL",
      "description": "SSL/TLS certificate management for SignalK",
      "location": "/plugins/signalk-ssl/"
    }
  },
  "peerDependencies": {
    "@signalk/server-api": "^2.0.0"
  },
  "dependencies": {
    "@peculiar/x509": "^1.12.3",
    "@sinclair/typebox": "^0.34.49",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@hookform/resolvers": "^5.4.0",
    "@signalk/server-api": "^2.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jsdom": "^29.1.1",
    "prettier": "^3.7.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^8.0.14",
    "vitest": "^3.0.0",
    "wouter": "^3.10.0",
    "zod": "^4.4.3"
  }
}
